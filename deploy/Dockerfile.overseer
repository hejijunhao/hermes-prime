FROM python:3.11-slim

# System deps
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# ttyd binary (architecture-aware)
RUN ARCH=$(uname -m) && \
    curl -fsSL "https://github.com/tsl0922/ttyd/releases/download/1.7.7/ttyd.${ARCH}" \
      -o /usr/local/bin/ttyd && \
    chmod +x /usr/local/bin/ttyd

# Python deps (cached layer — install will partially fail without source,
# but pip caches the downloaded wheels for the real install below)
COPY pyproject.toml setup.cfg* setup.py* /app/
WORKDIR /app
RUN pip install --no-cache-dir -e ".[hunter]" || echo "Pre-install skipped (source not yet copied)"

# Full source
COPY . /app
RUN pip install --no-cache-dir -e ".[hunter]"

# Environment
ENV HERMES_HOME=/data/hermes

# Git config
RUN git config --global user.name "Hermes Overseer" && \
    git config --global user.email "overseer@hermes-prime"

# Entrypoint
COPY deploy/overseer-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 8080
CMD ["/usr/local/bin/entrypoint.sh"]
